                        <term_definitions code="at0121">
                            <items id="text">12 Sexual function problem</items>
                            <items id="description">Patient reported statement on how big a problem sexual function or lack of sexual function has been over past 4 weeks.</items>
                            <items id="comment">Original questionnaire question: Overall, how big a problem has your sexual function or lack of sexual function been for you during the last 4 weeks?</items>
                        </term_definitions>
                        <term_definitions code="at0122">
                            <items id="text">No problem</items>
                            <items id="description">Sexual function or lack of sexual function has not been a problem.</items>
                        </term_definitions>
                        <term_definitions code="at0123">
                            <items id="text">Very small problem</items>
                            <items id="description">Sexual function or lack of sexual function has been a very small problem.</items>
                        </term_definitions>
                        <term_definitions code="at0124">
                            <items id="text">Small problem</items>
                            <items id="description">Sexual function or lack of sexual function has been a small problem.</items>
                        </term_definitions>
                        <term_definitions code="at0125">
                            <items id="text">Moderate problem</items>
                            <items id="description">Sexual function or lack of sexual function has been a moderate problem.</items>
                        </term_definitions>
                        <term_definitions code="at0126">
                            <items id="text">Big problem</items>
                            <items id="description">Sexual function or lack of sexual function has been a big problem.</items>
                        </term_definitions>
                        <term_definitions code="at0127">
                            <items id="text">13a Hot flushes</items>
                            <items id="description">Patient reported statement on how big a problem hot flushes have been in past 4 weeks.</items>
                            <items id="comment">Original questionnaire question: How big a problem during the last 4 weeks, if any, has each of the following been for you? a. Hot flushes.</items>
                        </term_definitions>
                        <term_definitions code="at0128">
                            <items id="text">13b Breast tenderness/enlargement</items>
                            <items id="description">Patient reported statement on how big a problem breast tenderness/enlargement has been in past 4 weeks.</items>
                            <items id="comment">Original questionnaire question: How big a problem during the last 4 weeks, if any, has each of the following been for you? b. Breast tenderness/enlargement.</items>
                        </term_definitions>
                        <term_definitions code="at0129">
                            <items id="text">13c Feeling depressed</items>
                            <items id="description">Patient reported statement on how big a problem feeling depressed has been in past 4 weeks.</items>
                            <items id="comment">Original questionnaire question: How big a problem during the last 4 weeks, if any, has each of the following been for you? c. Feeling depressed.</items>
                        </term_definitions>
                        <term_definitions code="at0130">
                            <items id="text">13d Lack of energy</items>
                            <items id="description">Patient reported statement on how big a problem lack of energy has been in past 4 weeks.</items>
                            <items id="comment">Original questionnaire question: How big a problem during the last 4 weeks, if any, has each of the following been for you? d. Lack of energy.</items>
                        </term_definitions>
                        <term_definitions code="at0131">
                            <items id="text">13e Change in body weight</items>
                            <items id="description">Patient reported statement on how big a problem change in body weight has been in past 4 weeks.</items>
                            <items id="comment">Original questionnaire question: How big a problem during the last 4 weeks, if any, has each of the following been for you? e. Change in body weight.</items>
                        </term_definitions>
                        <term_definitions code="at0132">
                            <items id="text">No problem</items>
                            <items id="description">Hot flushes have not been a problem.</items>
                        </term_definitions>
                        <term_definitions code="at0133">
                            <items id="text">Very small problem</items>
                            <items id="description">Hot flushes have been a very small problem.</items>
                        </term_definitions>
                        <term_definitions code="at0134">
                            <items id="text">Small problem</items>
                            <items id="description">Hot flushes have been a small problem.</items>
                        </term_definitions>
