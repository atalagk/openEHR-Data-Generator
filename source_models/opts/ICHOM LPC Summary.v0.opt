                                <term_definitions code="at0000">
                                    <items id="text">Primary treatment modalities</items>
                                    <items id="description">Description of treatment modalities.</items>
                                </term_definitions>
                                <term_definitions code="at0001">
                                    <items id="text">Tree</items>
                                    <items id="description">@ internal @</items>
                                </term_definitions>
                                <term_definitions code="at0002">
                                    <items id="text">Primary treatment modalities used</items>
                                    <items id="description">Indication of the primary treatment modalities used for the patient.</items>
                                </term_definitions>
                                <term_definitions code="at0003">
                                    <items id="text">Watchful waiting</items>
                                    <items id="description">Primary treatment modality is watchful waiting.</items>
                                </term_definitions>
                                <term_definitions code="at0004">
                                    <items id="text">Active surveillance</items>
                                    <items id="description">Primary treatment modality is active surveillance.</items>
                                </term_definitions>
                                <term_definitions code="at0005">
                                    <items id="text">Radical prostatectomy</items>
                                    <items id="description">Primary treatment modality is radical prostatectomy.</items>
                                </term_definitions>
                                <term_definitions code="at0006">
                                    <items id="text">External beam radiation therapy</items>
                                    <items id="description">Primary treatment modality or treatment modality adjuvant following surgery is external beam therapy.</items>
                                </term_definitions>
                                <term_definitions code="at0007">
                                    <items id="text">Brachytherapy</items>
                                    <items id="description">Primary treatment modality is brachytherapy.</items>
                                </term_definitions>
                                <term_definitions code="at0008">
                                    <items id="text">Androgen deprivation therapy</items>
                                    <items id="description">Primary treatment modality is androgen deprivation therapy.</items>
                                </term_definitions>
                                <term_definitions code="at0009">
                                    <items id="text">Focal therapy</items>
                                    <items id="description">Primary treatment modality is focal therapy.</items>
                                </term_definitions>
                                <term_definitions code="at0010">
                                    <items id="text">Other</items>
                                    <items id="description">Primary treatment modality is other.</items>
                                </term_definitions>
                                <term_definitions code="at0011">
                                    <items id="text">Type of focal therapy</items>
                                    <items id="description">Narrative description of type of focal therapy used for patient.</items>
                                </term_definitions>
                                <term_definitions code="at0012">
                                    <items id="text">Salvage treatment modalities used</items>
                                    <items id="description">Indication of salvage treatment modalities used for patient in last year.</items>
                                </term_definitions>
                                <term_definitions code="at0013">
                                    <items id="text">Radical prostatectomy</items>
                                    <items id="description">Salvage treatment modality is radical prostatectomy.</items>
                                </term_definitions>
                                <term_definitions code="at0014">
                                    <items id="text">External beam radiation therapy</items>
                                    <items id="description">Salvage treatment modality is external beam radiation therapy.</items>
                                </term_definitions>
                                <term_definitions code="at0015">
                                    <items id="text">Brachytherapy</items>
                                    <items id="description">Salvage treatment modality is brachytherapy.</items>
                                </term_definitions>
                                <term_definitions code="at0016">
