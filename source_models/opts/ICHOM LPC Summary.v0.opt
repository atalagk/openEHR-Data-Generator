                        <archetype_id>
                            <value>openEHR-EHR-OBSERVATION.briganti_risk_score.v0</value>
                        </archetype_id>
                        <term_definitions code="at0000">
                            <items id="text">Briganti Risk Score</items>
                            <items id="description">The Briganti risk score is a score for predicting probabilities of survival, recurrence, lymph node involvement, organ-defined involvement, extracapsular extension and seminal invasion.</items>
                        </term_definitions>
                        <term_definitions code="at0001">
                            <items id="text">Event Series</items>
                            <items id="description">@ internal @</items>
                        </term_definitions>
                        <term_definitions code="at0002">
                            <items id="text">Point in time</items>
                            <items id="description">A specific date and/or time which may be explicitly defined in a template or at run-time.</items>
                        </term_definitions>
                        <term_definitions code="at0003">
                            <items id="text">Tree</items>
                            <items id="description">@ internal @</items>
                        </term_definitions>
                        <term_definitions code="at0004">
                            <items id="text">Age</items>
                            <items id="description">Patient age when risk score is calculated.</items>
                        </term_definitions>
                        <term_definitions code="at0005">
                            <items id="text">PSA level before biopsy</items>
                            <items id="description">PSA level from laboratory report before the biopsy.</items>
                        </term_definitions>
                        <term_definitions code="at0019">
                            <items id="text">Tumour Staging</items>
                            <items id="description">Clinical tumor stage is determined by digital rectal examination and does not include stages determined by imaging studies.&#13;
What was your clinical tumor stage, using the AJCC Version 7/2010 Staging System?&#13;
Note: Although it is possible to be stage TX or stage T4, this nomogram is not applicable for these stages.</items>
                        </term_definitions>
                        <term_definitions code="at0020">
                            <items id="text">Positive biopsy cores</items>
                            <items id="description">Number of positive cores taken during biopsy. Information on cores taken at biopsy is optional. The nomogram can provide predictions without this information if not available. However, using this information, the nomogram can provide more refined predictions.</items>
                        </term_definitions>
                        <term_definitions code="at0021">
                            <items id="text">Negative biopsy cores</items>
                            <items id="description">Number of negative cores taken during biopsy. Information on cores taken at biopsy is optional. The nomogram can provide predictions without this information if not available. However, using this information, the nomogram can provide more refined predictions.</items>
                        </term_definitions>
                        <term_definitions code="at0022">
                            <items id="text">Percentage positive</items>
                            <items id="description">What percentage of the biopsy samples taken were positive?</items>
                        </term_definitions>
                        <term_definitions code="at0023">
                            <items id="text">Probability 10-year survival</items>
                            <items id="description">Probability of cancer-specific survival for 10 years after radical prostatectomy.</items>
                        </term_definitions>
                        <term_definitions code="at0024">
                            <items id="text">Probability 15-year survival</items>
                            <items id="description">Probability of cancer-specific survival for 15 years after radical prostatectomy.</items>
                        </term_definitions>
                        <term_definitions code="at0025">
                            <items id="text">Progression free probability 5 years</items>
                            <items id="description">Progression-free probability for 5 years after radical prostatectomy.</items>
                        </term_definitions>
                        <term_definitions code="at0026">
                            <items id="text">Progression free probability 10 years</items>
                            <items id="description">Progression-free probability for 10 years after radical prostatectomy.</items>
                        </term_definitions>
                        <term_definitions code="at0027">
                            <items id="text">Organ-confined disease probability</items>
                            <items id="description">This number shows, as a percentage, the probability that the cancer will be found to be confined to the prostate gland when the prostate is removed.</items>
                        </term_definitions>
                        <term_definitions code="at0028">
                            <items id="text">Extra-capsular extension probability</items>
                            <items id="description">This number shows, as a percentage, the probability of “extracapsular extension,” meaning the probability that the cancer extends through the capsule of the prostate into the surrounding tissue.</items>
                        </term_definitions>
                        <term_definitions code="at0029">
                            <items id="text">Lymph node involvement probability</items>
                            <items id="description">This number shows, as a percentage, the probability that prostate cancer has spread to the pelvic lymph nodes.</items>
                        </term_definitions>
                        <term_definitions code="at0030">
                            <items id="text">Seminal invasion probability</items>
                            <items id="description">This number shows, as a percentage, the probability of “seminal vesicle invasion,” which occurs when prostate cancer has spread into the seminal vesicles — glands attached to the prostate that help to produce semen. This number shows the probability that the cancer has spread to one or both seminal vesicles.</items>
                        </term_definitions>
                        <term_definitions code="at0031">
                            <items id="text">Tree</items>
                            <items id="description">@ internal @</items>
                        </term_definitions>
                        <term_definitions code="at0032">
                            <items id="text">Confounding factors</items>
                            <items id="description">Description of any incidental factors that may have contributed to the score.</items>
                        </term_definitions>
                        <term_definitions code="at0033">
                            <items id="text">Tree</items>
                            <items id="description">@ internal @</items>
                        </term_definitions>
                        <term_definitions code="at0034">
                            <items id="text">Extension</items>
                            <items id="description">Additional information required to capture local content or to align with other reference models/formalisms.</items>
                            <items id="comment">e.g. Local information requirements or additional metadata to align with FHIR or CIMI equivalents.</items>
                        </term_definitions>
                        <term_definitions code="at0035">
                            <items id="text">Gleason Grade</items>
                            <items id="description">Primary, secondary and tertiary Gleason grades and Total Gleason score.</items>
                        </term_definitions>
                    </children>
