                                        <archetype_id>
                                            <value>openEHR-EHR-CLUSTER.gleason_score.v0</value>
                                        </archetype_id>
                                        <term_definitions code="at0000">
                                            <items id="text">Gleason Score</items>
                                            <items id="description">Gleason Score (ISUP2005 version) - a prostate cancer grading score ratified by the International Society of Urological Pathologists (ISUP), including Gleason Grade Groups.</items>
                                        </term_definitions>
                                        <term_definitions code="at0166">
                                            <items id="text">Clinical Primary Gleason grade</items>
                                            <items id="description">The primary Gleason grade.</items>
                                        </term_definitions>
                                        <term_definitions code="at0182">
                                            <items id="text">Clinical Secondary Gleason grade</items>
                                            <items id="description">The secondary Gleason grade.</items>
                                        </term_definitions>
                                        <term_definitions code="at0183">
                                            <items id="text">Tertiary Gleason grade</items>
                                            <items id="description">The tertiary Gleason grade.</items>
                                        </term_definitions>
                                        <term_definitions code="at0197">
                                            <items id="text">Clinical total Gleason score</items>
                                            <items id="description">The sum of the primary and secondary Gleason grades.</items>
                                            <items id="comment">The total Gleason score does not take account of the tertiary Gleason grade.</items>
                                        </term_definitions>
                                        <term_definitions code="at0250">
                                            <items id="text">Grade 1</items>
                                            <items id="description">The cancerous prostate closely resembles normal prostate tissue. The glands are small, well-formed, and closely packed.</items>
                                        </term_definitions>
                                        <term_definitions code="at0251">
                                            <items id="text">Grade 2</items>
                                            <items id="description">The tissue still has well-formed glands, but they are larger and have more tissue between them.</items>
                                        </term_definitions>
                                        <term_definitions code="at0252">
                                            <items id="text">Grade 3</items>
                                            <items id="description">The tissue still has recognizable glands, but the cells are darker. At high magnification, some of these cells have left the glands and are beginning to invade the surrounding tissue.</items>
                                        </term_definitions>
                                        <term_definitions code="at0253">
                                            <items id="text">Grade 4</items>
                                            <items id="description">The tissue has few recognizable glands. Many cells are invading the surrounding tissue.</items>
                                        </term_definitions>
                                        <term_definitions code="at0254">
                                            <items id="text">Grade 5</items>
                                            <items id="description">The tissue does not have recognizable glands. There are often just sheets of cells throughout the surrounding tissue.</items>
                                        </term_definitions>
                                        <term_definitions code="at0255">
                                            <items id="text">Grade 1</items>
                                            <items id="description">The cancerous prostate closely resembles normal prostate tissue. The glands are small, well-formed, and closely packed.</items>
                                        </term_definitions>
                                        <term_definitions code="at0256">
                                            <items id="text">Grade 2</items>
                                            <items id="description">The tissue still has well-formed glands, but they are larger and have more tissue between them.</items>
                                        </term_definitions>
                                        <term_definitions code="at0257">
                                            <items id="text">Grade 3</items>
                                            <items id="description">The tissue still has recognizable glands, but the cells are darker. At high magnification, some of these cells have left the glands and are beginning to invade the surrounding tissue.</items>
                                        </term_definitions>
                                        <term_definitions code="at0258">
                                            <items id="text">Grade 4</items>
                                            <items id="description">The tissue has few recognizable glands. Many cells are invading the surrounding tissue.</items>
                                        </term_definitions>
                                        <term_definitions code="at0259">
                                            <items id="text">Grade 5</items>
                                            <items id="description">The tissue does not have recognizable glands. There are often just sheets of cells throughout the surrounding tissue.</items>
                                        </term_definitions>
                                        <term_definitions code="at0260">
                                            <items id="text">Grade 1</items>
                                            <items id="description">The cancerous prostate closely resembles normal prostate tissue. The glands are small, well-formed, and closely packed.</items>
                                        </term_definitions>
                                        <term_definitions code="at0261">
                                            <items id="text">Grade 2</items>
                                            <items id="description">The tissue still has well-formed glands, but they are larger and have more tissue between them.</items>
                                        </term_definitions>
                                        <term_definitions code="at0262">
                                            <items id="text">Grade 3</items>
                                            <items id="description">The tissue still has recognizable glands, but the cells are darker. At high magnification, some of these cells have left the glands and are beginning to invade the surrounding tissue.</items>
                                        </term_definitions>
                                        <term_definitions code="at0263">
                                            <items id="text">Grade 4</items>
                                            <items id="description">The tissue has few recognizable glands. Many cells are invading the surrounding tissue.</items>
                                        </term_definitions>
                                        <term_definitions code="at0264">
                                            <items id="text">Grade 5</items>
                                            <items id="description">The tissue does not have recognizable glands. There are often just sheets of cells throughout the surrounding tissue.</items>
                                        </term_definitions>
                                        <term_definitions code="at0265">
                                            <items id="text">Gleason Grade Group</items>
                                            <items id="description">The Gleason Grade Group.</items>
                                        </term_definitions>
                                        <term_definitions code="at0266">
                                            <items id="text">Grade Group 1</items>
                                            <items id="description">Gleason score less than or equal to 6.</items>
                                        </term_definitions>
                                        <term_definitions code="at0267">
                                            <items id="text">Grade Group 2</items>
                                            <items id="description">Gleason score 7 (Primary grade 3 + Secondary grade 4).</items>
                                        </term_definitions>
                                        <term_definitions code="at0268">
                                            <items id="text">Grade Group 3</items>
                                            <items id="description">Gleason score 7 (Primary grade 4 + Secondary grade 3).</items>
                                        </term_definitions>
                                        <term_definitions code="at0269">
                                            <items id="text">Grade Group 4</items>
                                            <items id="description">Gleason score 8.</items>
                                        </term_definitions>
                                        <term_definitions code="at0270">
                                            <items id="text">Grade Group 5</items>
                                            <items id="description">Gleason score 9-10.</items>
                                        </term_definitions>
