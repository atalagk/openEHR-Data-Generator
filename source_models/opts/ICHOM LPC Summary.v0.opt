                        <term_definitions code="at0000">
                            <items id="text">ICHOM LPC EPIC-26 Questionnaire</items>
                            <items id="description">Questionnaire and score designed to measure quality of life issues in patients with prostrate cancer.</items>
                        </term_definitions>
                        <term_definitions code="at0001">
                            <items id="text">Event Series</items>
                            <items id="description">@ internal @</items>
                        </term_definitions>
                        <term_definitions code="at0002">
                            <items id="text">Point in time</items>
                            <items id="description">Specified point in time which may be explicitly defined in a template or at run-time.</items>
                        </term_definitions>
                        <term_definitions code="at0003">
                            <items id="text">Tree</items>
                            <items id="description">@ internal @</items>
                        </term_definitions>
                        <term_definitions code="at0004">
                            <items id="text">1 Urine leakage</items>
                            <items id="description">Patient reported statement about frequency of urine leakage in past 4 weeks.</items>
                            <items id="comment">Orinal questionnaire question: Over the past 4 weeks, how often have you leaked urine?</items>
                        </term_definitions>
                        <term_definitions code="at0005">
                            <items id="text">More than once a day</items>
