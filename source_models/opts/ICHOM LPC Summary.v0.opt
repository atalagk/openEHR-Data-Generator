                                                    <value>openEHR-EHR-CLUSTER.ichom_lpc_procedure_details.v0</value>
                                                </archetype_id>
                                                <term_definitions code="at0000">
                                                    <items id="text">ICHOM LPC procedure details</items>
                                                    <items id="description">Procedure details for ICHOM LPC dataset.</items>
                                                </term_definitions>
                                                <term_definitions code="at0002">
                                                    <items id="text">External beam radiation therapy total dose</items>
                                                    <items id="description">Indication of the total dose of external beam radiation therapy.</items>
                                                </term_definitions>
                                                <term_definitions code="at0003">
                                                    <items id="text">External beam radiation therapy average dose per fraction</items>
                                                    <items id="description">Indication of the average dose per fraction of external beam radiation therapy.</items>
                                                </term_definitions>
                                                <term_definitions code="at0005">
                                                    <items id="text">External beam radiation therapy ongoing</items>
                                                    <items id="description">Indication if external beam radiation therapy is ongoing.</items>
                                                </term_definitions>
                                                <term_definitions code="at0007">
                                                    <items id="text">Brachytherapy dose</items>
                                                    <items id="description">Indication whether high-dose or low-dose brachytherapy was given.</items>
                                                </term_definitions>
                                                <term_definitions code="at0008">
                                                    <items id="text">High</items>
                                                    <items id="description">High dose of brachytherapy was given.</items>
                                                </term_definitions>
                                                <term_definitions code="at0009">
                                                    <items id="text">Low</items>
                                                    <items id="description">Low dose of brachytherapy was given.</items>
                                                </term_definitions>
                                                <term_definitions code="at0010">
                                                    <items id="text">Unknown</items>
                                                    <items id="description">Dose of brachytherapy is unknown.</items>
                                                </term_definitions>
                                                <term_definitions code="at0011">
                                                    <items id="text">Brachytherapy ongoing</items>
                                                    <items id="description">Indication whether brachytherapy is ongoing.</items>
                                                </term_definitions>
                                                <term_definitions code="at0013">
                                                    <items id="text">Prostatectomy nerve-sparing status</items>
                                                    <items id="description">Indication if the surgical approach was nerve-sparing or non-nerve-sparing.</items>
                                                </term_definitions>
                                                <term_definitions code="at0014">
                                                    <items id="text">Non-nerve-sparing</items>
                                                    <items id="description">Surgical approach was non-nerve-sparing.</items>
                                                </term_definitions>
                                                <term_definitions code="at0015">
                                                    <items id="text">Nerve-sparing</items>
                                                    <items id="description">Surgical approach was nerve-sparing.</items>
                                                </term_definitions>
                                                <term_definitions code="at0016">
                                                    <items id="text">Focal therapy ongoing</items>
                                                    <items id="description">Indication if focal therapy is ongoing.</items>
                                                </term_definitions>
                                                <term_definitions code="at0017">
                                                    <items id="text">Androgen deprivation therapy ongoing</items>
                                                    <items id="description">Indication if androgen deprivation therapy is ongoing.</items>
                                                </term_definitions>
                                                <term_definitions code="at0018">
                                                    <items id="text">Other therapy ongoing</items>
                                                    <items id="description">Indication if other therapy is ongoing.</items>
                                                </term_definitions>
                                            </children>
