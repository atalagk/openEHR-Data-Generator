                        <archetype_id>
                            <value>openEHR-EHR-OBSERVATION.ichom_lpc_eortc_pr25.v0</value>
                        </archetype_id>
                        <term_definitions code="at0000">
                            <items id="text">ICHOM LPC EORTC-PR25 libido questionnaire</items>
                            <items id="description">Questionnaire and score designed to measure patient-reported sexual activity details.</items>
                        </term_definitions>
                        <term_definitions code="at0001">
                            <items id="text">Event Series</items>
                            <items id="description">@ internal @</items>
                        </term_definitions>
                        <term_definitions code="at0002">
                            <items id="text">Any event</items>
                            <items id="description">A specific date and/or time which may be explicitly defined in a template or at run-time.</items>
                        </term_definitions>
                        <term_definitions code="at0003">
                            <items id="text">Tree</items>
                            <items id="description">@ internal @</items>
                        </term_definitions>
                        <term_definitions code="at0004">
                            <items id="text">1 Interest in sex</items>
                            <items id="description">Patient reported statement about interest in sex in the past 4 weeks.</items>
                            <items id="comment">Original questionnaire question: During the last 4 weeks, to what extent were you interested in sex?</items>
                        </term_definitions>
                        <term_definitions code="at0005">
                            <items id="text">Not at all</items>
                            <items id="description">Patient has not been interested in sex at all.</items>
                        </term_definitions>
                        <term_definitions code="at0006">
                            <items id="text">A little</items>
                            <items id="description">Patient has been a little interested in sex.</items>
                        </term_definitions>
                        <term_definitions code="at0007">
                            <items id="text">Quite a bit</items>
                            <items id="description">Patient has been quite a bit interested in sex.</items>
                        </term_definitions>
                        <term_definitions code="at0008">
                            <items id="text">Very much</items>
                            <items id="description">Patient has been very much interested in sex.</items>
                        </term_definitions>
                        <term_definitions code="at0009">
                            <items id="text">2 Utilitisation of sexual medications/devices</items>
                            <items id="description">Patient reported statement about utilisation of sexual medications/devices.</items>
                            <items id="comment">Original questionnaire question: Have you used any medications or devices to aid or improve erections?</items>
                        </term_definitions>
                        <term_definitions code="at0010">
                            <items id="text">No</items>
                            <items id="description">Patient has not been using sexual medications/devices.</items>
                        </term_definitions>
                        <term_definitions code="at0011">
                            <items id="text">Yes</items>
                            <items id="description">Patient has been using sexual medications/devices.</items>
                        </term_definitions>
                        <term_definitions code="at0012">
                            <items id="text">3a Viagra or another pill</items>
                            <items id="description">Patient reported statement on utilisation of viagra or another pill.</items>
                            <items id="comment">Original questionnaire question: For each of the following medicines or devices, please indicate whether or not you have tried or currently use it to improve your erections:  a. Viagra or another pill</items>
                        </term_definitions>
                        <term_definitions code="at0013">
                            <items id="text">Not tried</items>
                            <items id="description">Patient has not tried using Viagra or another pill.</items>
                        </term_definitions>
                        <term_definitions code="at0014">
                            <items id="text">Tried, not helpful</items>
                            <items id="description">Patient tried using Viagra or another pill, but did not find it helpful.</items>
                        </term_definitions>
                        <term_definitions code="at0015">
                            <items id="text">Helped, not using now</items>
                            <items id="description">Patient found Viagra or another pill helpful, but is not using it now.</items>
                        </term_definitions>
                        <term_definitions code="at0016">
                            <items id="text">Helped and using sometimes</items>
                            <items id="description">Patient found Viagra or another pill helpful and is using it sometimes.</items>
                        </term_definitions>
                        <term_definitions code="at0017">
                            <items id="text">Helped and using always</items>
                            <items id="description">Patient found Viagra or another pill helpful and is using it always.</items>
                        </term_definitions>
                        <term_definitions code="at0018">
                            <items id="text">3b Muse</items>
                            <items id="description">Patient reported statement on utilisation of Muse (intra-urethral alprostadil suppository).</items>
                            <items id="comment">For each of the following medicines or devices, please indicate whether or not you have tried or currently use it to improve your erections: b. Muse (intra-urethral alprostadil suppository)&#13;
</items>
                        </term_definitions>
                        <term_definitions code="at0019">
                            <items id="text">Not tried</items>
                            <items id="description">Patient has not tried using Muse.</items>
                        </term_definitions>
                        <term_definitions code="at0020">
                            <items id="text">Tried, not helpful</items>
                            <items id="description">Patient has tried Muse, but didn't find it helpful.</items>
                        </term_definitions>
                        <term_definitions code="at0021">
                            <items id="text">Helped, not using now</items>
                            <items id="description">Patient found Muse helpful, but is not using it now.</items>
                        </term_definitions>
                        <term_definitions code="at0022">
                            <items id="text">Helped and using sometimes</items>
                            <items id="description">Patient found Muse helpful and is using it sometimes.</items>
                        </term_definitions>
                        <term_definitions code="at0023">
                            <items id="text">Helped and using always</items>
                            <items id="description">Patient found Muse helpful and is using it always.</items>
                        </term_definitions>
                        <term_definitions code="at0024">
                            <items id="text">3c Penile injection therapy</items>
                            <items id="description">Patient reported statement about utilisation of penile injection therapy (such as caverject).</items>
                            <items id="comment">For each of the following medicines or devices, please indicate whether or not you have tried or currently use it to improve your erections: c. Penile injection therapy (such as caverject).&#13;
</items>
                        </term_definitions>
                        <term_definitions code="at0025">
                            <items id="text">Not tried</items>
                            <items id="description">Patient has not tried penile injection therapy.</items>
                        </term_definitions>
                        <term_definitions code="at0026">
                            <items id="text">Tried, not helpful</items>
                            <items id="description">Patient has tried penile injection therapy, but did not find it helpful.</items>
                        </term_definitions>
                        <term_definitions code="at0027">
                            <items id="text">Helped, not using now</items>
                            <items id="description">Patient found penile injection therapy helpful, but is not using it now.</items>
                        </term_definitions>
                        <term_definitions code="at0028">
                            <items id="text">Helped and using sometimes</items>
                            <items id="description">Patient found penile injection therrapy helpful and is using it sometimes.</items>
                        </term_definitions>
                        <term_definitions code="at0029">
                            <items id="text">Helped and using always</items>
                            <items id="description">Patient found penile injection therapy helpful and is using it always.</items>
                        </term_definitions>
                        <term_definitions code="at0030">
                            <items id="text">3d Vacuum erection device</items>
                            <items id="description">Patient reported statement about the utilisation of a vacuum erection device (such as erect-aid).</items>
                            <items id="comment">For each of the following medicines or devices, please indicate whether or not you have tried or currently use it to improve your erections: d. Vacuum erection device (such as erect-aid).&#13;
</items>
                        </term_definitions>
                        <term_definitions code="at0031">
                            <items id="text">Not tried</items>
                            <items id="description">Patient has not tried a vacuum erection device.</items>
                        </term_definitions>
                        <term_definitions code="at0032">
                            <items id="text">Tried, not helpful</items>
