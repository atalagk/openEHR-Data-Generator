                                        </term_definitions>
                                        <term_definitions code="at0000.1">
                                            <items id="text">Tumour - Prostate Cancer TNM staging 7th Edition</items>
                                            <items id="description">For the classification and grading of prostate cancer using the TNM classification 7th Edition.</items>
                                        </term_definitions>
                                        <term_definitions code="at0000">
                                            <items id="text">Tumour - TNM Cancer staging 7th Edition</items>
                                            <items id="description">A framework for the classification and grading of malignancies using the TNM classification system 7th Edition.</items>
                                        </term_definitions>
                                        <term_definitions code="at0003">
                                            <items id="text">Clinical primary tumour (T)</items>
                                            <items id="description">Assessment of the primary tumour.</items>
                                        </term_definitions>
                                        <term_definitions code="at0004">
                                            <items id="text">Clinical regional lymph nodes (N)</items>
                                            <items id="description">Assessment of the regional lymph nodes.</items>
                                        </term_definitions>
                                        <term_definitions code="at0005">
                                            <items id="text">Distant metastasis (M)</items>
                                            <items id="description">Assessment of distant metastasis.</items>
                                        </term_definitions>
                                        <term_definitions code="at0010">
                                            <items id="text">Overall staging</items>
                                            <items id="description">The overall staging derived from each T, N and M component e.g T1aM0NX. May include additional TNM descriptors.</items>
                                        </term_definitions>
                                        <term_definitions code="at0012">
                                            <items id="text">Comment</items>
                                            <items id="description">A text comment on the staging.</items>
                                        </term_definitions>
                                        <term_definitions code="at0014">
                                            <items id="text">Stage grouping</items>
                                            <items id="description">The TNM Stage grouping.</items>
                                        </term_definitions>
                                        <term_definitions code="at0025">
                                            <items id="text">Residual tumour (R)</items>
                                            <items id="description">Assessment of post-treatment residual tumour.</items>
                                        </term_definitions>
                                        <term_definitions code="at0046">
                                            <items id="text">Histopathological grading (G)</items>
                                            <items id="description">TNM histopathological grading classification. </items>
                                        </term_definitions>
                                        <term_definitions code="at0047">
                                            <items id="text">GX</items>
                                            <items id="description">Grade of differentiation cannot be assessed.</items>
                                        </term_definitions>
                                        <term_definitions code="at0048">
                                            <items id="text">G1</items>
                                            <items id="description">Well differentiated.</items>
                                        </term_definitions>
                                        <term_definitions code="at0049">
                                            <items id="text">G2</items>
                                            <items id="description">Moderately differentiated.</items>
                                        </term_definitions>
                                        <term_definitions code="at0050">
                                            <items id="text">G3</items>
                                            <items id="description">Poorly differentiated.</items>
                                        </term_definitions>
                                        <term_definitions code="at0051">
                                            <items id="text">G4</items>
                                            <items id="description">Undifferentiated.</items>
                                        </term_definitions>
                                        <term_definitions code="at0052">
                                            <items id="text">Descriptors</items>
                                            <items id="description">Additional tumour specific TNM descriptors.</items>
                                        </term_definitions>
                                        <term_definitions code="at0053">
                                            <items id="text">Descriptor</items>
                                            <items id="description">Additional tumour specific TNM descriptor.</items>
                                        </term_definitions>
