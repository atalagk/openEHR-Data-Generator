                    <archetype_id>
                      <value>openEHR-EHR-CLUSTER.overcrowding_screening.v0</value>
                    </archetype_id>
                    <term_definitions code="at0000">
                      <items id="description">Screening to identify when a dwelling is too small for the size and composition of the household living in it.</items>
                      <items id="text">Overcrowding screening</items>
                    </term_definitions>
                    <term_definitions code="at0001">
                      <items id="description">Number of people per room in a dwelling.</items>
                      <items id="text">Persons per room</items>
                    </term_definitions>
                    <term_definitions code="at0002">
                      <items id="description">Number of people per bedroom in a dwelling.</items>
                      <items id="text">Persons per bedroom</items>
                    </term_definitions>
                  </children>
                  <cardinality>
                    <is_ordered>false</is_ordered>
                    <is_unique>false</is_unique>
                    <interval>
                      <lower_included>true</lower_included>
                      <lower_unbounded>false</lower_unbounded>
                      <upper_unbounded>true</upper_unbounded>
                      <lower>1</lower>
                    </interval>
                  </cardinality>
                </attributes>
                <archetype_id>
                  <value>openEHR-EHR-CLUSTER.dwelling.v0</value>
                </archetype_id>
                <term_definitions code="at0000">
                  <items id="comment">The intended scope of dwelling includes, but is not limited to: a building; part of a building; house; apartment; prison; houseboat; mobile home; or vehicle. It can also include the spaces associated with a structure or property, including the basement or yard.</items>
                  <items id="description">An overview about the properties of a single structure, or a discrete space within a structure, and associated spaces in which an individual lives.</items>
                  <items id="text">Dwelling</items>
                </term_definitions>
                <term_definitions code="at0001">
                  <items id="comment">For example: if basic living facilities are located on the same level.</items>
                  <items id="description">Narrative description about all aspects of the dwelling.</items>
                  <items id="text">Overall description</items>
                </term_definitions>
                <term_definitions code="at0002">
                  <items id="comment">Coding of the dwelling type with a terminology is preferred, where possible. The value sets for this data element are likely to vary between jurisdictions - it is anticipated that they will usually be set within a use-case specific template. For example: 'separate house'; 'flat, unit or apartment'; 'caravan or tent'; or 'house or flat attached to a shop or office'.</items>
                  <items id="description">The type of dwelling in which an individual lives.</items>
                  <items id="text">Type</items>
                </term_definitions>
                <term_definitions code="at0003">
                  <items id="comment">This SLOT may be used to nest additional archetypes describing additional details about the dwelling that may be local to a jurisdiction.</items>
                  <items id="description">Further structured details about the dwelling.</items>
                  <items id="text">Additional details</items>
                </term_definitions>
                <term_definitions code="at0004">
                  <items id="description">Additional narrative about the dwelling, not captured in other fields.</items>
                  <items id="text">Comment</items>
                </term_definitions>
                <term_definitions code="at0005">
                  <items id="comment">Multiple occurrences will allow details for each access to be recorded. For example: driveway; path; fencing and gates; external stairs or lifts; doorsteps; electric door opener; rails; front access; rear access; lighting; or ramps for wheelchairs.</items>
                  <items id="description">Description about access to and egress from the dwelling.</items>
                  <items id="text">Access/egress</items>
                </term_definitions>
                <term_definitions code="at0006">
                  <items id="comment">Multiple occurrences will allow details for each entrance to be recorded. For example: weight and type of door; door handle; lock mechanism; or threshold step.</items>
                  <items id="description">Description about an entrance to the dwelling.</items>
                  <items id="text">Entrance</items>
                </term_definitions>
                <term_definitions code="at0007">
                  <items id="comment">Multiple occurrences will allow details for each parking area to be recorded. The scope for this data element includes cars, motor scooters and other vehicles that require dedicated space or storage outside the home. For example: single/double car park; space to transfer in/out of car; protection from weather; overhead clearance; or garage door details.</items>
                  <items id="description">Description about vehicle parking at or near the dwelling.</items>
                  <items id="text">Parking</items>
                </term_definitions>
                <term_definitions code="at0008">
                  <items id="comment">Multiple occurrences will allow details for each hallway to be recorded. For example: floor coverings; trip hazards; lighting or width.</items>
                  <items id="description">Description about the hallway within the dwelling.</items>
                  <items id="text">Hallway</items>
                </term_definitions>
                <term_definitions code="at0009">
                  <items id="comment">Multiple occurrences will allow details for each set of internal stairs or lifts to be recorded. For example: number of steps; condition; lighting; banister; or open/closed risers.</items>
                  <items id="description">Description about internal steps and lifts within the dwelling.</items>
                  <items id="text">Internal stairs/lifts</items>
                </term_definitions>
                <term_definitions code="at0010">
                  <items id="comment">Multiple occurrences will allow details for each living room to be recorded. For example: access; circulation space; trip hazards; floor coverings; window; lighting; or chair height.</items>
                  <items id="description">Description about a living room within the dwelling.</items>
                  <items id="text">Living room</items>
                </term_definitions>
                <term_definitions code="at0011">
                  <items id="comment">Multiple occurrences will allow details for each kitchen to be recorded. For example: access; circulation space; trip hazards; storage space; lighting; bench heights; or appliances.</items>
                  <items id="description">Description about a kitchen within the dwelling.</items>
                  <items id="text">Kitchen</items>
                </term_definitions>
                <term_definitions code="at0012">
                  <items id="comment">Multiple occurrences will allow details for each bedroom to be recorded. For example: access; bed size and type; bed height; circulation space; window; trip hazards; floor coverings; bedside light; or telephone.</items>
                  <items id="description">Description about a bedroom within the dwelling.</items>
                  <items id="text">Bedroom</items>
                </term_definitions>
                <term_definitions code="at0013">
                  <items id="comment">Multiple occurrences will allow details for each toilet fixture to be recorded. The toilet fixture could be located within a separate toilet room, within a bathroom or within another space in the dwelling or property. For example: location; access; circulation space; emergency access; height of seat pan and distance from walls; or grab rails.</items>
                  <items id="description">Description about a toilet fixture within the dwelling.</items>
                  <items id="text">Toilet</items>
                </term_definitions>
                <term_definitions code="at0014">
                  <items id="comment">Multiple occurrences will allow details for each bathroom to be recorded. For example: location; access; type of bathing facility - shower/bath/shower over bath; bath height; recess size; screen; window; taps; lighting; or grab rails.</items>
                  <items id="description">Description about a bathroom within the dwelling.</items>
                  <items id="text">Bathroom</items>
                </term_definitions>
                <term_definitions code="at0015">
                  <items id="comment">Multiple occurrences will allow details for each space with laundry facilities to be recorded. The laundry facilities could be located within a separate laundry room or within another space in the dwelling or property. For example: access; circulation space; trip hazards; or clothes line location and height.</items>
                  <items id="description">Description about a laundry facility within, or associated with, the dwelling.</items>
                  <items id="text">Laundry facilities</items>
                </term_definitions>
                <term_definitions code="at0016">
                  <items id="comment">Multiple occurrences will allow details for each outdoor space to be recorded. The intended scope of an outdoor space includes, but is not limited to: a yard; rooftop terrace; balcony; porch; garage; or shed. For example: current condition; size; access; slope; surface; stairs; or maintenance needs.</items>
                  <items id="description">Description about an outdoor space associated with the the dwelling.</items>
                  <items id="text">Outdoor space</items>
                </term_definitions>
                <term_definitions code="at0017">
                  <items id="comment">Multiple occurrences will allow physical details for each landline phone to be recorded, regardless of the technology used to connect. For example: physical location of fixed phone or base stations; or presence of mobile handsets.</items>
                  <items id="description">Description about a landline telephone within the dwelling.</items>
                  <items id="text">Landline phone</items>
                </term_definitions>
                <term_definitions code="at0018">
                  <items id="comment">Multiple occurrences will allow details for each fire protection system to be recorded. The intended scope for a fire protection system includes, but is not limited to: smoke and carbon monoxide detectors; fire extinguishers; or sprinklers. For example: location; in working order; maintenance needs; central monitoring; or serial connections.</items>
                  <items id="description">Description about fire protection within the dwelling.</items>
                  <items id="text">Fire protection</items>
                </term_definitions>
                <term_definitions code="at0020">
                  <items id="comment">Multiple occurrences will allow details for each doorbell to be recorded. For example: vibrating, flashing or audible; pitch; or volume.</items>
                  <items id="description">Description about a doorbell or alert system within the dwelling.</items>
                  <items id="text">Doorbell</items>
                </term_definitions>
                <term_definitions code="at0021">
                  <items id="comment">Multiple occurrences will allow details for each type of rubbish collection to be recorded. For example: location of rubbish bins or chute; or type of bins.</items>
                  <items id="description">Description about rubbish bins and waste collection at the dwelling.</items>
                  <items id="text">Rubbish collection</items>
                </term_definitions>
                <term_definitions code="at0022">
                  <items id="description">Description about mail delivery and collection at the dwelling.</items>
                  <items id="text">Mail</items>
                </term_definitions>
                <term_definitions code="at0023">
                  <items id="comment">Multiple occurrences will allow details for each water supply to be recorded. For example: piped water (in house); stand pipe; or yard pipe.</items>
                  <items id="description">Description about how water is delivered into the dwelling.</items>
                  <items id="text">Water supply</items>
                </term_definitions>
                <term_definitions code="at0024">
                  <items id="comment">For example: commercial collection; burning; burying; field; or river.</items>
                  <items id="description">Description about the system of rubbish disposal from the dwelling.</items>
                  <items id="text">Rubbish disposal</items>
                </term_definitions>
                <term_definitions code="at0025">
                  <items id="comment">Multiple occurrences will allow details for each water storage to be recorded. For example: none; tank; or drum.</items>
                  <items id="description">Description about the storage of potable water at the dwelling.</items>
                  <items id="text">Water storage</items>
                </term_definitions>
                <term_definitions code="at0026">
                  <items id="comment">Multiple occurrences will allow details for each toilet fixture to be recorded. For example: flush toilet; or pit latrine.</items>
                  <items id="description">Description about the type of toilet fixture at the dwelling.</items>
                  <items id="text">Toilet type</items>
                </term_definitions>
                <term_definitions code="at0028">
                  <items id="description">The number of bedrooms in the dwelling.</items>
                  <items id="text">Number of bedrooms</items>
                </term_definitions>
                <term_definitions code="at0029">
                  <items id="description">The number of bathrooms in the dwelling.</items>
                  <items id="text">Number of bathrooms</items>
                </term_definitions>
                <term_definitions code="at0033">
                  <items id="comment">Multiple occurrences will allow details for each water source to be recorded. This data element may be used to differentiate between public and private sources as well as the type of source. For example: public; lake; private well; borehole; rain; or water vendors.</items>
                  <items id="description">Description about the source of water used at the dwelling.</items>
                  <items id="text">Water source</items>
                </term_definitions>
                <term_definitions code="at0034">
                  <items id="comment">Multiple occurrences will allow details for each type of sewage disposal to be recorded. For example: septic tank or cesspit; or public sewage system.</items>
                  <items id="description">Description about the disposal of sewage from the dwelling.</items>
                  <items id="text">Sewage disposal</items>
                </term_definitions>
                <term_definitions code="at0035">
                  <items id="comment">The toilet fixture could be located within a bathroom or similar space, or a separate toilet room. For example: toilet suite; urinal, pit latrine.</items>
                  <items id="description">The number of toilet fixtures in the dwelling.</items>
                  <items id="text">Number of toilets</items>
                </term_definitions>
                <term_definitions code="at0036">
                  <items id="comment">For example: leaking roof; rising damp; mould in the bathroom; broken floorboards; or holes in the walls.</items>
                  <items id="description">Narrative description about the overall condition of the dwelling.</items>
                  <items id="text">Condition</items>
                </term_definitions>
                <term_definitions code="at0037">
                  <items id="comment">Multiple occurrences will allow details for each heating/cooling source to be recorded. For example: central heating; open fire; or air conditioning.</items>
                  <items id="description">Description about how the dwelling is heated and cooled.</items>
                  <items id="text">Heating/cooling</items>
                </term_definitions>
                <term_definitions code="at0038">
                  <items id="comment">Multiple occurrences will allow details for each energy supply to be recorded. For example: mains electricity; solar power; bottle gas; home generator; or fire wood.</items>
                  <items id="description">Description about sources of power to the dwelling.</items>
                  <items id="text">Energy supply</items>
                </term_definitions>
                <term_definitions code="at0039">
                  <items id="comment">Multiple occurrences will allow details for each security and safety measure to be recorded.</items>
                  <items id="description">Description about security and safety measures within the dwelling.</items>
                  <items id="text">Security and safety</items>
                </term_definitions>
                <term_definitions code="at0040">
                  <items id="comment">Multiple occurrences will allow details for each form of connectivity to be recorded. For example: internet access; cable; or PSTN line.</items>
                  <items id="description">Description about the internet and other forms of connectivity and communication within the dwelling.</items>
                  <items id="text">Connectivity</items>
                </term_definitions>
                <term_definitions code="at0041">
                  <items id="description">The number of floors within the dwelling.</items>
                  <items id="text">Number of floors</items>
                </term_definitions>
                <term_definitions code="at0042">
                  <items id="comment">For example: hot water for hygiene; a refrigerator for food hygiene and safe medication storage.</items>
                  <items id="description">Availability of critical appliances or services at the dwelling, which may support use of clinical decision support.</items>
                  <items id="text">Critical appliances/services</items>
                </term_definitions>
                <term_definitions code="at0043">
                  <items id="comment">Multiple occurrences will allow details for each appliance to be recorded. For example: refrigerator; hot water boiler; clothes washer/dryer or dishwasher.</items>
                  <items id="description">Description about an appliance at the dwelling.</items>
                  <items id="text">Appliance</items>
                </term_definitions>
                <term_definitions code="at0044">
                  <items id="description">Access to a refrigerator to store food and medications.</items>
                  <items id="text">Refrigerator</items>
                </term_definitions>
                <term_definitions code="at0045">
                  <items id="description">Access to hot running water for washing.</items>
                  <items id="text">Hot running water</items>
                </term_definitions>
              </children>
              <cardinality>
                <is_ordered>false</is_ordered>
                <is_unique>false</is_unique>
                <interval>
                  <lower_included>true</lower_included>
                  <lower_unbounded>false</lower_unbounded>
                  <upper_unbounded>true</upper_unbounded>
                  <lower>0</lower>
                </interval>
              </cardinality>
            </attributes>
          </children>
        </attributes>
