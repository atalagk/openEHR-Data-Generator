        <archetype_id>
          <value>openEHR-EHR-EVALUATION.living_arrangement.v0</value>
        </archetype_id>
        <term_definitions code="at0000">
          <items id="comment">This information will provide a sense of the level of support, both physically and emotionally, to which an individual may have access.</items>
          <items id="description">The circumstances about an individual living alone or with others.</items>
          <items id="text">Living arrangement</items>
        </term_definitions>
        <term_definitions code="at0001">
          <items id="description">@ internal @</items>
          <items id="text">Item tree</items>
        </term_definitions>
        <term_definitions code="at0002">
          <items id="description">@ internal @</items>
          <items id="text">Item tree</items>
        </term_definitions>
        <term_definitions code="at0003">
          <items id="description">Narrative description about the living arrangements.</items>
          <items id="text">Description</items>
        </term_definitions>
        <term_definitions code="at0004">
          <items id="comment">Coding of the living arrangement with a terminology is preferred, where possible. The value sets for this data element are likely to vary between jurisdictions - it is anticipated that they will usually be set within a use-case specific template. For example: 'lives alone'; 'lives with family'; or 'lives with others'.</items>
          <items id="description">Single word or phrase that describes if an individual usually resides alone or with others.</items>
          <items id="text">Living arrangement</items>
        </term_definitions>
        <term_definitions code="at0005">
          <items id="comment">Coding of the household composition with a terminology is preferred, where possible. For example: single; sole parent with children aged less than 16 years; couple; couple with children aged less than 16 years; family; family with other non-related members present; or group of unrelated adults.</items>
          <items id="description">Single word or phrase that describes the relationship between people who reside together.</items>
          <items id="text">Household composition</items>
        </term_definitions>
        <term_definitions code="at0006">
          <items id="description">Narrative description about the relationship between people who reside together.</items>
          <items id="text">Household description</items>
        </term_definitions>
        <term_definitions code="at0007">
          <items id="description">The number of individuals who are in the household.</items>
          <items id="text">Number of household members</items>
        </term_definitions>
        <term_definitions code="at0008">
          <items id="comment">This SLOT may be used to nest additional archetypes describing additional details about living arrangements that may be local to a jurisdiction.</items>
          <items id="description">Further details about the living arrangement.</items>
          <items id="text">Additional details</items>
        </term_definitions>
        <term_definitions code="at0009">
          <items id="description">Narrative description about the pets who reside with an individual.</items>
          <items id="text">Pets</items>
        </term_definitions>
        <term_definitions code="at0010">
          <items id="description">Additional narrative about the living arrangement not captured in other fields.</items>
          <items id="text">Comment</items>
        </term_definitions>
        <term_definitions code="at0011">
          <items id="comment">For example: local information requirements; or additional metadata to align with FHIR.</items>
          <items id="description">Additional information required to extend the model with local content or to align with other reference models/formalisms.</items>
          <items id="text">Extension</items>
        </term_definitions>
        <term_definitions code="at0012">
          <items id="description">The date this summary was last updated.</items>
          <items id="text">Last updated</items>
        </term_definitions>
