        <term_definitions code="at0000">
          <items id="description">Details about travel during an interval of time.</items>
          <items id="text">Travel event</items>
        </term_definitions>
        <term_definitions code="at0001">
          <items id="description">@ internal @</items>
          <items id="text">History</items>
        </term_definitions>
        <term_definitions code="at0002">
          <items id="description">Default, unspecified interval event which may be explicitly defined in a template or at run-time.</items>
          <items id="text">Any interval event</items>
        </term_definitions>
        <term_definitions code="at0003">
          <items id="description">@ internal @</items>
          <items id="text">Tree</items>
        </term_definitions>
        <term_definitions code="at0004">
          <items id="comment">Use the Event to set the relevant interval.</items>
          <items id="description">Has the individual travelled during the specified interval?</items>
          <items id="text">Travel?</items>
        </term_definitions>
        <term_definitions code="at0005">
          <items id="description">The individual has not travelled within the specified interval of time.</items>
          <items id="text">No</items>
        </term_definitions>
        <term_definitions code="at0006">
          <items id="description">The individual has travelled nationally within the specified interval of time.</items>
          <items id="text">Yes - national</items>
        </term_definitions>
        <term_definitions code="at0007">
          <items id="description">@ internal @</items>
          <items id="text">Item tree</items>
        </term_definitions>
        <term_definitions code="at0008">
          <items id="comment">The trip has a single departure and return date to their home base. A trip may include visiting many individual places, and these details should be recorded in the Itinerary.</items>
          <items id="description">Details about a single trip away from the home base.</items>
          <items id="text">Trip detail</items>
        </term_definitions>
        <term_definitions code="at0009">
          <items id="description">The date when the individual left their home base.</items>
          <items id="text">Date of departure</items>
        </term_definitions>
        <term_definitions code="at0010">
          <items id="description">Details about a single location visited on a trip.</items>
          <items id="text">Travel destination</items>
        </term_definitions>
        <term_definitions code="at0011">
          <items id="description">The country visited.</items>
          <items id="text">Country</items>
        </term_definitions>
        <term_definitions code="at0012">
          <items id="comment">Different regions within the same country maybe identified if they potentially pose different health risks.</items>
          <items id="description">The region visited.</items>
          <items id="text">State/region</items>
        </term_definitions>
        <term_definitions code="at0013">
          <items id="comment">Different cities within the same country or region maybe identified if they potentially pose different health risks.</items>
          <items id="description">The city visited.</items>
          <items id="text">City</items>
        </term_definitions>
        <term_definitions code="at0014">
          <items id="description">Date of entry to the identified location.</items>
          <items id="text">Date of entry</items>
        </term_definitions>
        <term_definitions code="at0015">
          <items id="description">Date of exit from the identified location.</items>
          <items id="text">Date of exit</items>
        </term_definitions>
        <term_definitions code="at0016">
          <items id="description">Narrative description about the visit to the location, especially about potential exposure to health risks.</items>
          <items id="text">Description</items>
        </term_definitions>
        <term_definitions code="at0017">
          <items id="description">Additional narrative about the stay at the identified location, not captured in other fields.</items>
          <items id="text">Comment</items>
        </term_definitions>
        <term_definitions code="at0018">
          <items id="comment">This may be useful if it is necessary to use contact tracing. For example: the carrier and ID of a flight or ship.</items>
          <items id="description">Details about how the individual returned to their home base.</items>
          <items id="text">Return transport</items>
        </term_definitions>
        <term_definitions code="at0019">
          <items id="description">The date when the individual returned back to their home base.</items>
          <items id="text">Date of return</items>
        </term_definitions>
        <term_definitions code="at0020">
          <items id="description">Additional narrative about the whole trip, not captured in other fields.</items>
          <items id="text">Comment</items>
        </term_definitions>
        <term_definitions code="at0021">
          <items id="comment">For example: local information requirements; or additional metadata to align with FHIR.</items>
          <items id="description">Additional information required to extend the model with local content or to align with other reference models or formalisms.</items>
          <items id="text">Extension</items>
        </term_definitions>
        <term_definitions code="at0022">
          <items id="description">Narrative description about the whole trip, especially about potential exposure to health risks.</items>
          <items id="text">Description</items>
        </term_definitions>
        <term_definitions code="at0023">
          <items id="description">The individual has travelled internationally within the specified interval of time.</items>
          <items id="text">Yes - international</items>
        </term_definitions>
        <term_definitions code="at0024">
          <items id="description">Additional structured details about the travel to, from and at the destination.</items>
          <items id="text">Additional destination details</items>
        </term_definitions>
        <term_definitions code="at0025">
          <items id="description">Additional structured details about the whole trip.</items>
          <items id="text">Additional trip details</items>
        </term_definitions>
