            <term_definitions code="at0000">
              <items id="description">Risk assessment for an individual who may have been exposed to an infectious agent.</items>
              <items id="text">Infectious exposure investigation</items>
            </term_definitions>
            <term_definitions code="at0001">
              <items id="description">@ internal @</items>
              <items id="text">Tree</items>
            </term_definitions>
            <term_definitions code="at0002">
              <items id="description">Identification of the organism, material, symptoms or condition to which the individual has been exposed.</items>
              <items id="text">Infectious agent</items>
            </term_definitions>
            <term_definitions code="at0003">
              <items id="description">Narrative description about the overall exposure.</items>
              <items id="text">Description</items>
            </term_definitions>
            <term_definitions code="at0004">
              <items id="description">Date/time of notification or report to authorities.</items>
              <items id="text">Date of notification/report</items>
            </term_definitions>
            <term_definitions code="at0005">
              <items id="comment">Multiple exposures can be recorded, using one instance of this cluster per exposure.</items>
              <items id="description">Details about a single exposure.</items>
              <items id="text">Specific exposure details</items>
            </term_definitions>
            <term_definitions code="at0006">
              <items id="comment">For example: airborne, direct contact, or needle stick.</items>
              <items id="description">Details about the method of exposure.</items>
              <items id="text">Description of exposure</items>
            </term_definitions>
            <term_definitions code="at0007">
              <items id="comment">Can be cloned in template and renamed for specific Date/time at onset of exposure and cessation of exposure.</items>
              <items id="description">Date and time of exposure.</items>
              <items id="text">Date/time of exposure</items>
            </term_definitions>
            <term_definitions code="at0008">
              <items id="description">Type of location.</items>
              <items id="text">Physical location category</items>
            </term_definitions>
            <term_definitions code="at0009">
              <items id="description">Narrative description about the physical location of the exposure.</items>
              <items id="text">Specific physical location</items>
            </term_definitions>
            <term_definitions code="at0011">
              <items id="description">The length of time of the exposure.</items>
              <items id="text">Duration of exposure</items>
            </term_definitions>
            <term_definitions code="at0012">
              <items id="comment">For example: direct contact; shared room; or shared ward.</items>
              <items id="description">Closeness of contact.</items>
              <items id="text">Proximity of contact</items>
            </term_definitions>
            <term_definitions code="at0013">
              <items id="description">Risk assessment about the exposure to the infectious agent.</items>
              <items id="text">Risk stratification</items>
            </term_definitions>
            <term_definitions code="at0015">
              <items id="description">Structured details about the person who is the source of infection.</items>
              <items id="text">Source individual details</items>
            </term_definitions>
            <term_definitions code="at0016">
              <items id="description">Factors which may have contributed to the infectious contact.</items>
              <items id="text">Contributory factors</items>
            </term_definitions>
            <term_definitions code="at0017">
              <items id="description">Structured details about the person who has been exposed or infected.</items>
              <items id="text">Exposed individual details</items>
            </term_definitions>
            <term_definitions code="at0018">
              <items id="comment">For example: finger in a needle stick injury.</items>
              <items id="description">The place on the body where the exposed individual has been exposed.</items>
              <items id="text">Exposed anatomical location</items>
            </term_definitions>
            <term_definitions code="at0019">
              <items id="description">Structured details about the exposed anatomical location.</items>
              <items id="text">Anatomical location details</items>
            </term_definitions>
