                    <archetype_id>
                      <value>openEHR-EHR-CLUSTER.occupation_record.v1</value>
                    </archetype_id>
                    <term_definitions code="at0000">
                      <items id="description">A single job or role carried out by an individual during a specified period of time.</items>
                      <items id="text">Occupation record</items>
                    </term_definitions>
                    <term_definitions code="at0001">
                      <items id="comment">For example: unpaid; paid; self-employed; or volunteer. Coding with a terminology is desirable, where possible.</items>
                      <items id="description">The status of a worker in terms of being paid or unpaid.</items>
                      <items id="text">Paid employment status</items>
                    </term_definitions>
                    <term_definitions code="at0002">
                      <items id="comment">For example: Mining, manufacturing, construction. Coding with a terminology is desirable, where possible.</items>
                      <items id="description">The type of industry in which the individual works.</items>
                      <items id="text">Industry category</items>
                    </term_definitions>
                    <term_definitions code="at0004">
                      <items id="description">Details about the employer or institution.</items>
                      <items id="text">Organisation details</items>
                    </term_definitions>
                    <term_definitions code="at0005">
                      <items id="comment">For example: Chief Executive Officer; Carer; or Student. Each of these job titles or roles may be comprised of multiple duties.</items>
                      <items id="description">The main job title or the role of the individual.</items>
                      <items id="text">Job title/role</items>
                    </term_definitions>
                    <term_definitions code="at0006">
                      <items id="comment">Coding with a terminology is desirable, where possible, such as ISCO-08.
For example: Sales manager or software engineer.</items>
                      <items id="description">The type of job undertaken by the individual.</items>
                      <items id="text">Job category</items>
                    </term_definitions>
                    <term_definitions code="at0007">
                      <items id="description">The date when an individual commenced the job or role.</items>
                      <items id="text">Date commenced</items>
                    </term_definitions>
                    <term_definitions code="at0008">
                      <items id="description">The date when an individual ceased working in a job or role.</items>
                      <items id="text">Date ceased</items>
                    </term_definitions>
                    <term_definitions code="at0013">
                      <items id="comment">Full time equivalent may also be known as 'FTE'. For example: 0.5; 50 %; or "part time".</items>
                      <items id="description">The time spent in this job or role relative to full-time.</items>
                      <items id="text">Full time equivalent</items>
                    </term_definitions>
                    <term_definitions code="at0014">
                      <items id="description">Additional narrative about the occupation record not captured in other fields.</items>
                      <items id="text">Comment</items>
                    </term_definitions>
                    <term_definitions code="at0016">
                      <items id="description">Narrative description about the job or role carried out by the individual.</items>
                      <items id="text">Description</items>
                    </term_definitions>
                    <term_definitions code="at0018">
                      <items id="comment">For example: workplace location and conditions; or combat zone experience.</items>
                      <items id="description">Further detail about an occupation record.</items>
                      <items id="text">Additional details</items>
                    </term_definitions>
                    <term_definitions code="at0019">
                      <items id="comment">For example: '3 days per week', '10 days per month' or '2 hours per day'.</items>
                      <items id="description">The amount of time an individual is allocated to carry out the job or role per specified period of this occupation record.</items>
                      <items id="text">Time allocated</items>
                    </term_definitions>
                    <term_definitions code="at0020">
                      <items id="description">The individual carries out this occupation for equal to or more than the amount of time that is officially regarded as 'full-time' for the occupation.</items>
                      <items id="text">Full-time</items>
                    </term_definitions>
                    <term_definitions code="at0021">
                      <items id="description">The individual carries out this occupation for less than the amount of time that is officially regarded as 'full-time' for the occupation.</items>
                      <items id="text">Part-time</items>
                    </term_definitions>
                  </children>
