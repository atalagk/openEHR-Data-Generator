                        <term_definitions code="at0000">
                            <items id="text">Question for MDT</items>
                            <items id="description">The reason for initiation of any healthcare encounter or contact by the individual who is the subject of care.</items>
                        </term_definitions>
                        <term_definitions code="at0001">
                            <items id="text">Tree</items>
                            <items id="description">@ internal @</items>
                        </term_definitions>
                        <term_definitions code="at0002">
                            <items id="text">Contact type</items>
                            <items id="description">Identification of the type, or administrative category, of healthcare sought or required by the subject of care.</items>
                            <items id="comment">Coding of the 'Contact type' with a terminology is desirable, where possible. Examples include: pre-employment medical, routine antenatal visit, women's health check, pre-operative assessment, or annual medical check-up.&#13;
</items>
                        </term_definitions>
                        <term_definitions code="at0004">
                            <items id="text">Question to MDT</items>
                            <items id="description">Identification of the clinical or social problem motivating the subject of care to seeking healthcare.</items>
                            <items id="comment">Coding of the 'Presenting problem' with a terminology is desirable, where possible. Clinical or social reasons for seeking healthcare can include health issues, symptoms or physical signs. Examples: health issues - desire to quit smoking, domestic violence; symptoms - abdominal pain, shortness of breath; physical signs - an altered conscious state. 'Chief complaint' may be used as a valid synonym for 'Presenting problem' in templates.&#13;
 </items>
                        </term_definitions>
