                            <items id="text">Pulmonary Fibrosis</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::48447003">
                            <items id="text">Chronic heart failure</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::414545008">
                            <items id="text">Ischemic heart disease</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::38341003">
                            <items id="text">Hypertension</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::328383001">
                            <items id="text">Liver disease</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::414915002">
                            <items id="text">Obesity</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::2492009">
                            <items id="text">Malnutrition</items>
