                                                                <archetype_id>
                                                                    <value>openEHR-EHR-CLUSTER.inspired_oxygen.v1</value>
                                                                </archetype_id>
                                                                <term_definitions code="at0000">
                                                                    <items id="text">Inspired oxygen</items>
                                                                    <items id="description">The amount of oxygen being delivered, or to be delivered, to the patient given as a fraction, percentage or indirectly as a flow rate.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0051">
                                                                    <items id="text">Flow rate</items>
                                                                    <items id="description">Oxygen flow rate given to an individual.</items>
                                                                    <items id="comment">For example '5 l/min'.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0052">
                                                                    <items id="text">FiO₂</items>
                                                                    <items id="description">Fraction of oxygen in inspired air.</items>
                                                                    <items id="comment">For example: '0.28'.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0053">
                                                                    <items id="text">Percent O₂</items>
                                                                    <items id="description">Percentage of oxygen in inspired air.</items>
                                                                    <items id="comment">For example: '24 %'</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0054">
                                                                    <items id="text">Method of oxygen delivery</items>
                                                                    <items id="description">The method used to deliver the oxygen.</items>
                                                                    <items id="comment">Intended to capture only simple description / terms, for example: 'nasal prongs'. The 'Oxygen delivery detail' slot may be used for more detailed or complex recording.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0057">
                                                                    <items id="text">On air</items>
                                                                    <items id="description">The patient is receiving air, equivalent to 21% O₂ or 0.21 FiO₂ and an oxygen flow rate of 0 litres per minute.</items>
                                                                    <items id="comment">Where 'On air' is set to true, Flow rate, FiO₂ and Percent O₂ should not be recorded. Conversely 'On air' should be omitted if Flow rate, FiO₂ or Percent O₂ are recorded.</items>
                                                                </term_definitions>
                                                                <term_definitions code="at0058">
                                                                    <items id="text">Oxygen delivery detail</items>
                                                                    <items id="description">Further details of the method of oxygen delivery.</items>
                                                                    <items id="comment">For example details of humidification or assisted ventilation.</items>
                                                                </term_definitions>
                                                            </children>
                                                            <cardinality>
                                                                <is_ordered>false</is_ordered>
                                                                <is_unique>false</is_unique>
                                                                <interval>
                                                                    <lower_included>true</lower_included>
                                                                    <upper_included>false</upper_included>
