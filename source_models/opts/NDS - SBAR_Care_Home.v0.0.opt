                        <term_definitions code="SNOMED-CT::46635009">
                            <items id="text">Type 1 Diabetes</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::44054006">
                            <items id="text">Type 2 Diabetes</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::128283000">
                            <items id="text">Chronic Neurological Disorder</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::709044004">
                            <items id="text">Chronic Kidney Disease</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::62479008">
                            <items id="text">AIDS / HIV</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::69896004">
                            <items id="text">Rheumatological Disease (Rheumatoid Arthritis)</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::52448006">
                            <items id="text">Dementia</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::266987004">
                            <items id="text">Current/previous mailgnancy</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::426990007">
                            <items id="text">Home oxygen therapy</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::708409001">
                            <items id="text">Home nebulizer therapy</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::8771000175103">
                            <items id="text">Uses home continuous positive airway pressure ventilation supply (finding) |</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::722499006">
                            <items id="text">Vaper | Electronic cigarette user (finding) |</items>
                        </term_definitions>
