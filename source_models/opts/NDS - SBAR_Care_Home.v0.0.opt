                                                                    <terminology_id>
                                                                        <value>SNOMED-CT</value>
                                                                    </terminology_id>
                                                                    <code_string>[SNOMED-CT::162442009]</code_string>
                                                                </value>
                                                            </items>
                                                        </term_bindings>
                                                    </children>
