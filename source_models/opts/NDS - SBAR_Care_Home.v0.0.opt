                        <archetype_id>
                            <value>openEHR-EHR-OBSERVATION.condition_screening.v0</value>
                        </archetype_id>
                        <term_definitions code="at0000">
                            <items id="text">Significant comorbidities</items>
                            <items id="description">An individual- or self-reported questionnaire screening for conditions, including problems, diagnoses and pregnancy.</items>
                        </term_definitions>
                        <term_definitions code="at0001">
                            <items id="text">History</items>
                            <items id="description">@ internal @</items>
                        </term_definitions>
                        <term_definitions code="at0002">
                            <items id="text">Any event</items>
                            <items id="description">Default, unspecified point in time or interval event which may be explicitly defined in a template or at run-time.</items>
                        </term_definitions>
                        <term_definitions code="at0003">
                            <items id="text">Tree</items>
                            <items id="description">@ internal @</items>
                        </term_definitions>
                        <term_definitions code="at0004">
                            <items id="text">Condition name</items>
                            <items id="description">Name of the condition being screened.</items>
                        </term_definitions>
                        <term_definitions code="at0005">
                            <items id="text">Presence?</items>
                            <items id="description">Presence of the condition.</items>
                        </term_definitions>
                        <term_definitions code="at0006">
                            <items id="text">Onset</items>
                            <items id="description">The date/time when the condition was first noticed by the individual or diagnosed by a clinician.</items>
                            <items id="comment">Partial dates are allowed.</items>
                        </term_definitions>
                        <term_definitions code="at0007">
                            <items id="text">Item tree</items>
                            <items id="description">@ internal @</items>
                        </term_definitions>
                        <term_definitions code="at0021">
                            <items id="text">Extension</items>
                            <items id="description">Additional information required to capture local content or to align with other reference models/formalisms.</items>
                            <items id="comment">For example: local information requirements or additional metadata to align with FHIR or CIMI equivalents.</items>
                        </term_definitions>
                        <term_definitions code="at0022">
                            <items id="text">Pregnancy/postpartum</items>
                            <items id="description">Grouping of data elements related to screening for a single condition.</items>
                        </term_definitions>
                        <term_definitions code="at0023">
                            <items id="text">Present</items>
                            <items id="description">The specific condition is present.</items>
                        </term_definitions>
                        <term_definitions code="at0024">
                            <items id="text">Absent</items>
                            <items id="description">The specific condition is not present.</items>
                        </term_definitions>
                        <term_definitions code="at0025">
                            <items id="text">Other relevant co-morbidity</items>
                            <items id="description">Additional narrative about the conditions, not captured in other fields.</items>
                        </term_definitions>
                        <term_definitions code="at0026">
                            <items id="text">Additional details</items>
                            <items id="description">Additional structured details related to condition screening.</items>
                        </term_definitions>
                        <term_definitions code="at0027">
                            <items id="text">Indeterminate</items>
                            <items id="description">It is not possible to know if the condition is present or absent.</items>
                        </term_definitions>
                        <term_definitions code="at0028">
                            <items id="text">Presence of any conditions?</items>
                            <items id="description">Presence of any relevant conditions.</items>
                        </term_definitions>
                        <term_definitions code="at0029">
                            <items id="text">Pregnancy gestation</items>
                            <items id="description">The date/time when any conditions were first noticed.</items>
                            <items id="comment">Partial dates are allowed.</items>
                        </term_definitions>
                        <term_definitions code="at0031">
                            <items id="text">Present</items>
                            <items id="description">Conditions are present.</items>
                        </term_definitions>
                        <term_definitions code="at0032">
                            <items id="text">Absent</items>
                            <items id="description">Conditions are not present.</items>
                        </term_definitions>
                        <term_definitions code="at0033">
                            <items id="text">Indeterminate</items>
                            <items id="description">It is not possible to know if any conditions are present or absent.</items>
                        </term_definitions>
                        <term_definitions code="at0034">
                            <items id="text">Screening purpose</items>
                            <items id="description">The reason for overall screening.</items>
                            <items id="comment">For example: pre-operative screening.</items>
                        </term_definitions>
                        <term_definitions code="at0035">
                            <items id="text">Comment</items>
                            <items id="description">Additional narrative about the specific condition, not captured in other fields.</items>
                        </term_definitions>
                        <term_definitions code="at0036">
                            <items id="text">First trimester</items>
                            <items id="description">Between first day of last period and the end of week 12.</items>
                        </term_definitions>
                        <term_definitions code="at0037">
                            <items id="text">Second trimester</items>
                            <items id="description">Between week 13 and week 28.</items>
                        </term_definitions>
                        <term_definitions code="at0038">
                            <items id="text">Third trimester</items>
                            <items id="description">After week 28.</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::13645005">
                            <items id="text">COPD</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::195967001">
                            <items id="text">Asthma</items>
                        </term_definitions>
                        <term_definitions code="SNOMED-CT::12295008">
