            <archetype_id>
              <value>openEHR-EHR-EVALUATION.adverse.v1</value>
            </archetype_id>
            <term_definitions code="at0000">
              <items id="description">Recording the presence of a harmful or undesirable response to an agent or substance including food, as determined by the clinician - excluding poisoning and abnormal use</items>
              <items id="text">Adverse reaction</items>
            </term_definitions>
            <term_definitions code="at0002">
              <items id="description">@ internal @</items>
              <items id="text">structure</items>
            </term_definitions>
            <term_definitions code="at0003">
              <items id="description">The agent or substance or class that caused the adverse reaction.</items>
              <items id="text">Agent</items>
            </term_definitions>
            <term_definitions code="at0004">
              <items id="description">Degree of certainty that the agent was the cause of the reaction.</items>
              <items id="text">Probability of causation</items>
            </term_definitions>
            <term_definitions code="at0005">
              <items id="description">A reaction to the agent is deemed to be or have been present by the clinician.</items>
              <items id="text">Certain/Highly likely</items>
            </term_definitions>
            <term_definitions code="at0006">
              <items id="description">The reaction is deemed to be the probable cause of the reaction.</items>
              <items id="text">Probable</items>
            </term_definitions>
            <term_definitions code="at0007">
              <items id="description">The agent is deemed to be a possible cause of the reaction.</items>
              <items id="text">Possible</items>
            </term_definitions>
            <term_definitions code="at0010">
              <items id="description">The category of the agent.</items>
              <items id="text">Agent category</items>
            </term_definitions>
            <term_definitions code="at0011">
              <items id="description">A substance taken as part of the diet.</items>
              <items id="text">Food</items>
            </term_definitions>
            <term_definitions code="at0012">
              <items id="description">A living organism or its venom or produce.</items>
              <items id="text">Animal</items>
            </term_definitions>
            <term_definitions code="at0013">
              <items id="description">A substance taken or applied  for medicinal purposes.</items>
              <items id="text">Medication</items>
            </term_definitions>
            <term_definitions code="at0014">
              <items id="description">Non-medicinal chemicals or substances.</items>
              <items id="text">Other chemical or substance</items>
            </term_definitions>
            <term_definitions code="at0015">
              <items id="description">The type of reaction experience by the person as determined by the clinician.</items>
              <items id="text">Reaction category</items>
            </term_definitions>
            <term_definitions code="at0016">
              <items id="description">Leads to unpleasant symptoms which are sufficient to avoid use in the future.</items>
              <items id="text">Intolerance</items>
            </term_definitions>
            <term_definitions code="at0017">
              <items id="description">Leads to morbidity which is potentially threatening to the wellbeing of the person.</items>
              <items id="text">Sensitivity</items>
            </term_definitions>
            <term_definitions code="at0018">
              <items id="description">Leads to an IgE mediated reaction.</items>
              <items id="text">Allergy</items>
            </term_definitions>
            <term_definitions code="at0019">
              <items id="description">Details of the reaction experienced by the person.</items>
              <items id="text">Exposure and reaction detail</items>
            </term_definitions>
            <term_definitions code="at0020">
              <items id="description">The date (+/- time) when the person became exposed to the agent.</items>
              <items id="text">Date of exposure</items>
            </term_definitions>
            <term_definitions code="at0021">
              <items id="description">The duration of the exposure to the agent.</items>
              <items id="text">Duration of the exposure</items>
            </term_definitions>
            <term_definitions code="at0022">
              <items id="description">A description of the reaction to this agent as experienced by the person.</items>
              <items id="text">Reaction description</items>
            </term_definitions>
            <term_definitions code="at0023">
              <items id="description">The category of the reaction.</items>
              <items id="text">Reaction severity</items>
            </term_definitions>
            <term_definitions code="at0024">
              <items id="description">A reaction which causes little distress and no loss of work/school.</items>
              <items id="text">Mild</items>
            </term_definitions>
            <term_definitions code="at0025">
              <items id="description">A reaction which causes morbidity and/or loss of function.</items>
              <items id="text">Disabling</items>
            </term_definitions>
            <term_definitions code="at0026">
              <items id="description">A reaction which was or could be lifethreatening.</items>
              <items id="text">Life threatening</items>
            </term_definitions>
            <term_definitions code="at0027">
              <items id="description">The date/time the reaction commenced.</items>
              <items id="text">Date of onset of reaction</items>
            </term_definitions>
            <term_definitions code="at0028">
              <items id="description">The duration of the reaction.</items>
              <items id="text">Duration of the reaction</items>
            </term_definitions>
            <term_definitions code="at0030">
              <items id="description">Person has been exposed with no reaction.</items>
              <items id="text">No reaction</items>
            </term_definitions>
            <term_definitions code="at0031">
              <items id="description">A non-medicinal ingredient of medication such as colouring, preservative, etc.(subtype of other chemical)</items>
              <items id="text">Non-active ingredient of medication</items>
            </term_definitions>
            <term_definitions code="at0032">
              <items id="description">The specific substance that caused the reaction if different from the agent (e.g. brands or members of a class).</items>
              <items id="text">Specific substance</items>
            </term_definitions>
            <term_definitions code="at0033">
              <items id="description">A dye or media used in diagnostic imaging (subtype of other chemical).</items>
              <items id="text">Imaging dye or media</items>
            </term_definitions>
            <term_definitions code="at0034">
              <items id="description">An agent present in the environment.</items>
              <items id="text">Environmental</items>
            </term_definitions>
          </children>
