                        <term_definitions code="at0000">
                          <items id="description">Personal or organisational telephone, fax, and email details.</items>
                          <items id="text">Telecom details</items>
                        </term_definitions>
                        <term_definitions code="at0001">
                          <items id="description">One or more telecoms contacts for an individual.</items>
                          <items id="text">Telecoms</items>
                        </term_definitions>
                        <term_definitions code="at0002">
                          <items id="description">An unstructured description of telecoms.</items>
                          <items id="text">Unstuctured telecoms</items>
                        </term_definitions>
                        <term_definitions code="at0003">
                          <items id="description">A structure for telephone numbers composed of separately identifiable elements. ENV13606-4:2000 7.11.18</items>
                          <items id="text">Structured telecoms</items>
                        </term_definitions>
                        <term_definitions code="at0004">
                          <items id="description">Telecom mechanism e.g. telephone, facsimile, pager etc.  ENV 13606-4:2000 7.11.19</items>
                          <items id="text">Telecoms type</items>
                        </term_definitions>
                        <term_definitions code="at0005">
                          <items id="description">Telephone country code.  ENV13606-4:2000 7.11.18.</items>
                          <items id="text">Country code</items>
                        </term_definitions>
                        <term_definitions code="at0006">
                          <items id="description">Telephone area code.</items>
                          <items id="text">Area code</items>
                        </term_definitions>
                        <term_definitions code="at0007">
                          <items id="description">Telephone number.</items>
                          <items id="text">Number</items>
                        </term_definitions>
                        <term_definitions code="at0009">
                          <items id="description">Email address.</items>
                          <items id="text">Email address</items>
                        </term_definitions>
                        <term_definitions code="at0010">
                          <items id="description">A qualifier for a telecom contact, describing its context e.g. 'Work', 'Home'.   ENV 13606 - 4:2000 7.11.19.</items>
                          <items id="text">Mode</items>
                        </term_definitions>
                        <term_definitions code="at0011">
                          <items id="description">Telecommunication detail for home.</items>
                          <items id="text">Home</items>
                        </term_definitions>
                        <term_definitions code="at0012">
                          <items id="description">Telecommunication detail for work.</items>
                          <items id="text">Work</items>
                        </term_definitions>
                        <term_definitions code="at0013">
                          <items id="description">Telephone number details.</items>
                          <items id="text">Telephone</items>
                        </term_definitions>
                        <term_definitions code="at0014">
                          <items id="description">Facsimile number details.</items>
                          <items id="text">Fax</items>
                        </term_definitions>
                        <term_definitions code="at0015">
                          <items id="description">Mobile phone number details.</items>
                          <items id="text">Mobile phone</items>
                        </term_definitions>
                        <term_definitions code="at0016">
                          <items id="description">Pager number details.</items>
                          <items id="text">Pager</items>
                        </term_definitions>
                        <term_definitions code="at0018">
                          <items id="description">?.</items>
                          <items id="text">Contact</items>
                        </term_definitions>
                        <term_definitions code="at0019">
                          <items id="description">Telephone extension number.  ENV13606-4:2000 7.11.18.</items>
