                    <term_definitions code="at0000">
                      <items id="description">To record details of one or more personal addresses.</items>
                      <items id="text">Address</items>
                    </term_definitions>
                    <term_definitions code="at0001">
                      <items id="description">One or more adresses for an individual.</items>
                      <items id="text">Address</items>
                    </term_definitions>
                    <term_definitions code="at0002">
                      <items id="description">A postal address expressed in an unstructured format. ENV 13606 - 4:2000 7.11.15.</items>
                      <items id="text">Unstructured address</items>
                    </term_definitions>
                    <term_definitions code="at0003">
                      <items id="description">The structure of a postal address representing the residence of a patient or the physical location of an organisation.  ENV 13606-4:2000 7.11.1.</items>
                      <items id="text">Structured address</items>
                    </term_definitions>
                    <term_definitions code="at0004">
                      <items id="description">Post code.</items>
                      <items id="text">Post code</items>
                    </term_definitions>
                    <term_definitions code="at0005">
                      <items id="description">The number of the property.</items>
                      <items id="text">Property number</items>
                    </term_definitions>
                    <term_definitions code="at0006">
                      <items id="description">The type of address.</items>
                      <items id="text">Address Type</items>
                    </term_definitions>
                    <term_definitions code="at0007">
                      <items id="description">The start of the period for which this address is valid.</items>
                      <items id="text">Valid from</items>
                    </term_definitions>
                    <term_definitions code="at0008">
                      <items id="description">Date from which the Address is no longer valid.</items>
                      <items id="text">Valid to</items>
                    </term_definitions>
                    <term_definitions code="at0009">
                      <items id="description">A series of address lines.</items>
                      <items id="text">Address line</items>
                    </term_definitions>
                    <term_definitions code="at0011">
                      <items id="description">Address of place of residence.</items>
                      <items id="text">Residential</items>
                    </term_definitions>
                    <term_definitions code="at0012">
                      <items id="description">Address for correspondence.</items>
                      <items id="text">Correspondence</items>
                    </term_definitions>
                    <term_definitions code="at0013">
                      <items id="description">Address of place of business.</items>
                      <items id="text">Business</items>
                    </term_definitions>
                    <term_definitions code="at0014">
                      <items id="description">Temporary address.</items>
                      <items id="text">Temporary</items>
                    </term_definitions>
                    <term_definitions code="at0015">
                      <items id="description">The period during which the associated address is applicable to the person / organisation.  ENV 13606 - 4:2000 7.11.11.  This describes the actual period.</items>
                      <items id="text">AddressValid Period</items>
                    </term_definitions>
