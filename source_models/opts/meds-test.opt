                            <lower_included>true</lower_included>
                            <upper_included>false</upper_included>
                            <lower_unbounded>false</lower_unbounded>
                            <upper_unbounded>true</upper_unbounded>
                            <lower>0</lower>
                        </interval>
                    </cardinality>
                </attributes>
                <archetype_id>
                    <value>openEHR-EHR-SECTION.medication_list.v0</value>
                </archetype_id>
                <term_definitions code="at0004">
                    <items id="text">Medications</items>
                    <items id="description">Positive statements about the use of medications.</items>
                </term_definitions>
                <term_definitions code="at0005">
                    <items id="text">Exclusion statement</items>
                    <items id="description">A positive statement about the exclusion of the use of medications.</items>
                    <items id="comment">For example: "No known use of medication".</items>
                </term_definitions>
                <term_definitions code="at0006">
                    <items id="text">Absence statement</items>
                    <items id="description">A positive statement that no information is available about the use of medications.</items>
                    <items id="comment">For example: "No information available about use of medications".</items>
                </term_definitions>
                <term_definitions code="at0000">
                    <items id="text">Medication list</items>
                    <items id="description">Framework for consistent modelling of content within a template for a Medication list.</items>
                </term_definitions>
            </children>
