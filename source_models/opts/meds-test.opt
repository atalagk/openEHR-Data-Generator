                <archetype_id>
                    <value>openEHR-EHR-ACTION.review.v0</value>
                </archetype_id>
                <term_definitions code="at0001">
                    <items id="text">Tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0002">
                    <items id="text">Review activity</items>
                    <items id="description">Identification of the item or activity that is being reviewed.</items>
                    <items id="comment">Coding with a terminology is preferred, if available. For example: Medicines List; Care Plan Review; or File Review.</items>
                </term_definitions>
                <term_definitions code="at0003">
                    <items id="text">Review planned</items>
                    <items id="description">The review activity is planned.</items>
                </term_definitions>
                <term_definitions code="at0004">
                    <items id="text">Review scheduled</items>
                    <items id="description">The review activity has been scheduled.</items>
                </term_definitions>
                <term_definitions code="at0006">
                    <items id="text">Review performed</items>
                    <items id="description">The review activity has been performed.</items>
                </term_definitions>
                <term_definitions code="at0010">
                    <items id="text">Review postponed</items>
                    <items id="description">The review has been postponed.</items>
                </term_definitions>
                <term_definitions code="at0011">
                    <items id="text">Review suspended</items>
                    <items id="description">The review activity has been suspended.</items>
                </term_definitions>
                <term_definitions code="at0012">
                    <items id="text">Review cancelled</items>
                    <items id="description">The review activity has been cancelled.</items>
                </term_definitions>
                <term_definitions code="at0013">
                    <items id="text">Review aborted</items>
                    <items id="description">The review activity has been aborted.</items>
                </term_definitions>
                <term_definitions code="at0014">
                    <items id="text">Reason</items>
                    <items id="description">Reason that the care pathway step for the identified Review Activity was carried out.</items>
                    <items id="comment">For example, the reason for the cancellation or suspension of the Review Activity</items>
                </term_definitions>
                <term_definitions code="at0015">
                    <items id="text">Description</items>
                    <items id="description">Narrative description of the Review Activity relevant for the care pathway step.</items>
                    <items id="comment">For example: description of the Medicines Review that was performed; or the Care Plan review that is planned or scheduled.</items>
                </term_definitions>
                <term_definitions code="at0016">
                    <items id="text">Review completed</items>
                    <items id="description">The review activity has been completed.</items>
                </term_definitions>
                <term_definitions code="at0017">
                    <items id="text">Tree</items>
                    <items id="description">@ internal @</items>
                </term_definitions>
                <term_definitions code="at0018">
                    <items id="text">Start date/time</items>
