                },
                "localizedDescriptions": {
                  "en": "Estimated or actual date/time the diagnosis or problem was\n                                recognised by a healthcare professional.\n                            "
                },
                "aqlPath": "/content[openEHR-EHR-SECTION.problems_issues_rcp.v1]/items[openEHR-EHR-EVALUATION.problem_diagnosis.v1]/data[at0001]/items[at0003]/value",
                "inputs": [
                  {
                    "type": "DATETIME"
                  }
                ],
                "annotations": {
                  "comment": "Partial dates are acceptable. If the subject of care is under the age of\n                                one year, then the complete date or a minimum of the month and year is necessary to\n                                enable accurate age calculations - for example, if used to drive decision support. Data\n                                captured/imported as \"Age at time of clinical recognition\" should be converted to a date\n                                using the subject's date of birth.\n                            "
                }
