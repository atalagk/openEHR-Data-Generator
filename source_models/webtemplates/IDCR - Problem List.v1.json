                "aqlPath": "/content[openEHR-EHR-SECTION.problems_issues_rcp.v1]/items[openEHR-EHR-EVALUATION.problem_diagnosis.v1]/data[at0001]/items[at0012]/value",
                "inputs": [
                  {
                    "type": "TEXT"
                  }
                ],
                "annotations": {
                  "comment": "Coding of the name of the anatomical location with a terminology is\n                                preferred, where possible.\n                                Use this data element to record precoordinated anatomical locations. If the requirements\n                                for recording the anatomical location are determined at run-time by the application or\n                                require more complex modelling such as relative locations then use the\n                                CLUSTER.anatomical_location or CLUSTER.relative_location within the 'Structured\n                                anatomical location' SLOT in this archetype. Occurrences for this data element are\n                                unbounded to allow for clinical scenarios such as describing a rash in multiple\n                                locations but where all of the other attributes are identical. If the anatomical\n                                location is included in the Problem/diagnosis name via precoordinated codes, this data\n                                element becomes redundant.\n\n                            "
                }
              },
              {
                "id": "date_time_of_onset",
