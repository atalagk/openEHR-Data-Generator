                            "aqlPath": "/content[openEHR-EHR-OBSERVATION.smics_befund.v1]/data[at0001]/events[at0002]/data[at0003]/items[at0015]/items[openEHR-EHR-CLUSTER.erregerdetails.v1]/items[openEHR-EHR-CLUSTER.laboratory_test_panel.v0 and name/value='Antibiogramm']/items[openEHR-EHR-CLUSTER.laboratory_test_analyte.v1]/items[at0001 and name/value='Minimale Hemmkonzentration']/value",
