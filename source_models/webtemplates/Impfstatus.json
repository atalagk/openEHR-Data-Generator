                "localizedDescriptions": {
                  "de": "Beabsichtigte Reihenfolge dieser Dosierung in der Gesamtdosierungsfolge."
                },
                "aqlPath": "/content[openEHR-EHR-ACTION.medication.v1 and name/value='Impfung']/description[at0017]/items[openEHR-EHR-CLUSTER.dosage.v1 and name/value='Verabreichte Dosen']/items[at0164]/value",
                "inputs": [
                  {
                    "type": "INTEGER",
                    "validation": {
                      "range": {
                        "min": 1,
                        "minOp": ">="
                      }
                    }
                  }
                ],
                "annotations": {
                  "comment": "Zum Beispiel: '1', '2', '3'.\nWenn mehrere Dosierungen angegeben werden, gibt die 'Dosierungsreihenfolge' die Reihenfolge an, in der sie ausgef\u00fchrt werden soll. Zum Beispiel: (1) 1 Tablette am Morgen, (2) 2 Tabletten um 14 Uhr, (3) 1 Tablette am Abend."
                }
              },
