            "localizedDescriptions": {
              "de": "Die Art der Patientenverf\u00fcgung."
            },
            "aqlPath": "/content[openEHR-EHR-EVALUATION.advance_care_directive.v1 and name/value='DNR-Anordnung']/data[at0001]/items[at0005]/value",
            "inputs": [
