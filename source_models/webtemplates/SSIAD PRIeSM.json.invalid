                      "fr": "Degr\u00e9 auquel la peau est expos\u00e9e \u00e0 l'humidit\u00e9."
                    },
                    "aqlPath": "/content[openEHR-EHR-SECTION.adhoc.v1 and name/value='Braden Scale']/items[openEHR-EHR-OBSERVATION.braden_scale.v1]/data[at0001]/events[at0002]/data[at0003]/items[at0009]/value",
                    "inputs": [
                      {
                        "type": "CODED_TEXT",
                        "list": [
                          {
                            "value": "at0015",
                            "label": "Constamment humide",
                            "localizedLabels": {
                              "fr": "Constamment humide",
                              "en": "Constantly moist"
                            },
                            "localizedDescriptions": {
                              "fr": "La peau est maintenue humide presque constamment par la transpiration, l'urine, etc. L'humidit\u00e9 est d\u00e9tect\u00e9e chaque fois que le patient est d\u00e9plac\u00e9 ou retourn\u00e9.",
                              "en": "Skin is kept moist almost constantly by perspiration, urine etc. Dampness is detected every time patient is moved or turned."
                            },
                            "ordinal": 1
                          },
                          {
                            "value": "at0016",
                            "label": "Tr\u00e8s humide",
                            "localizedLabels": {
                              "fr": "Tr\u00e8s humide",
                              "en": "Very moist"
                            },
                            "localizedDescriptions": {
                              "fr": "*Skin is often, but not always moist. Linen must be changed as often as 3 times in 24 hours. (en)",
                              "en": "Skin is often, but not always moist. Linen must be changed as often as 3 times in 24 hours."
                            },
                            "ordinal": 2
                          },
                          {
                            "value": "at0017",
                            "label": "Parfois humide",
                            "localizedLabels": {
                              "fr": "Parfois humide",
                              "en": "Occasionally moist"
                            },
                            "localizedDescriptions": {
                              "fr": "La peau est parfois humide, ce qui n\u00e9cessite un changement de linge suppl\u00e9mentaire environ une fois par jour.",
                              "en": "Skin is occasionally moist, requiring an extra linen change approximately once a day."
                            },
                            "ordinal": 3
                          },
                          {
                            "value": "at0018",
                            "label": "Rarement humide",
                            "localizedLabels": {
                              "fr": "Rarement humide",
                              "en": "Rarely moist"
                            },
                            "localizedDescriptions": {
                              "fr": "La peau est g\u00e9n\u00e9ralement s\u00e8che, le linge ne doit \u00eatre chang\u00e9 qu'\u00e0 intervalles r\u00e9guliers.",
                              "en": "Skin is usually dry, linen only requires changing at routine intervals."
                            },
                            "ordinal": 4
                          }
                        ]
                      }
                    ]
