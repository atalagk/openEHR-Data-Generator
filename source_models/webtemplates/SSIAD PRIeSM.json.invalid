                "nodeId": "at0002",
                "min": 0,
                "max": -1,
                "localizedNames": {
                  "en": "Any event",
                  "fr": "N'importe quel evenement"
                },
                "localizedDescriptions": {
                  "en": "Default, unspecified point in time event which may be explicitly defined in a template or at run-time.",
                  "fr": "\u00c9v\u00e9nement ponctuel par d\u00e9faut non sp\u00e9cifi\u00e9 qui peut \u00eatre d\u00e9fini explicitement dans un mod\u00e8le ou au moment de l'ex\u00e9cution."
                },
                "aqlPath": "/content[openEHR-EHR-SECTION.adhoc.v1 and name/value='Braden Scale']/items[openEHR-EHR-OBSERVATION.braden_scale.v1]/data[at0001]/events[at0002]",
                "children": [
                  {
                    "id": "perception_sensorielle",
                    "name": "Perception sensorielle",
                    "localizedName": "Perception sensorielle",
                    "rmType": "DV_ORDINAL",
                    "nodeId": "at0004",
                    "min": 0,
                    "max": 1,
                    "localizedNames": {
                      "en": "Sensory perception",
                      "fr": "Perception sensorielle"
                    },
                    "localizedDescriptions": {
                      "en": "Ability to respond meaningfully to pressure-related discomfort.",
                      "fr": "Capacit\u00e9 \u00e0 r\u00e9agir de mani\u00e8re significative \u00e0 l'inconfort li\u00e9 \u00e0 la pression."
                    },
                    "aqlPath": "/content[openEHR-EHR-SECTION.adhoc.v1 and name/value='Braden Scale']/items[openEHR-EHR-OBSERVATION.braden_scale.v1]/data[at0001]/events[at0002]/data[at0003]/items[at0004]/value",
                    "inputs": [
                      {
                        "type": "CODED_TEXT",
                        "list": [
                          {
                            "value": "at0005",
                            "label": "Compl\u00e8tement limit\u00e9",
                            "localizedLabels": {
                              "fr": "Compl\u00e8tement limit\u00e9",
                              "en": "Completely limited"
                            },
                            "localizedDescriptions": {
                              "fr": "Ne r\u00e9pond pas (ne g\u00e9mit pas, ne bronche pas ou hal\u00e8te) aux stimuli douloureux, en raison d'une diminution du niveau de conscience ou de la s\u00e9dation. OU capacit\u00e9 limit\u00e9e \u00e0 ressentir de la douleur sur la majeure partie du corps.",
                              "en": "Unresponsive (does not moan, flinch, or grasp) to painful stimuli, due to diminished level of consciousness or sedation. OR limited ability to feel pain over most of body."
                            },
                            "ordinal": 1
                          },
                          {
                            "value": "at0006",
                            "label": "Tr\u00e8s limit\u00e9",
                            "localizedLabels": {
                              "fr": "Tr\u00e8s limit\u00e9",
                              "en": "Very limited"
                            },
                            "localizedDescriptions": {
                              "fr": "R\u00e9pond uniquement aux stimuli douloureux. Ne peut communiquer son inconfort que par des g\u00e9missements ou de l'agitation. OU a une d\u00e9ficience sensorielle qui limite la capacit\u00e9 de ressentir de la douleur ou de l'inconfort sur la moiti\u00e9 du corps.",
                              "en": "Responds only to painful stimuli. Cannot communicate discomfort except by moaning or restlessness. OR has a sensory impairment which limits the ability to feel pain or discomfort over 1/2 of body."
                            },
                            "ordinal": 2
                          },
                          {
                            "value": "at0007",
                            "label": "L\u00e9g\u00e8rement limit\u00e9",
                            "localizedLabels": {
                              "fr": "L\u00e9g\u00e8rement limit\u00e9",
                              "en": "Slightly limited"
                            },
                            "localizedDescriptions": {
                              "fr": "R\u00e9pond aux commandes verbales, mais ne peut pas toujours communiquer l'inconfort ou le besoin d'\u00eatre retourn\u00e9. OU a une certaine d\u00e9ficience sensorielle qui limite la capacit\u00e9 de ressentir de la douleur ou de l'inconfort dans 1 ou 2 extr\u00e9mit\u00e9s.",
                              "en": "Responds to verbal commands, but cannot always communicate discomfort or the need to be turned. OR has some sensory impairment which limits ability to feel pain or discomfort in 1 or 2 extremities."
                            },
                            "ordinal": 3
                          },
                          {
                            "value": "at0008",
                            "label": "Aucune d\u00e9ficience",
                            "localizedLabels": {
                              "fr": "Aucune d\u00e9ficience",
                              "en": "No impairment"
                            },
                            "localizedDescriptions": {
                              "fr": "R\u00e9pond aux commandes verbales. N'a pas de d\u00e9ficit sensoriel qui limiterait la capacit\u00e9 \u00e0 ressentir ou \u00e0 exprimer la douleur ou l'inconfort.",
                              "en": "Responds to verbal commands. Has no sensory deficit which would limit ability to feel or voice pain or discomfort."
                            },
                            "ordinal": 4
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "id": "humidit\u00e9",
                    "name": "Humidit\u00e9",
                    "localizedName": "Humidit\u00e9",
                    "rmType": "DV_ORDINAL",
                    "nodeId": "at0009",
