            "min": 0,
            "max": 1,
            "localizedNames": {
              "en": "Braden scale",
              "fr": "\u00c9chelle de Braden"
            },
            "localizedDescriptions": {
              "en": "The Braden scale is a tool used to assess the risk of pressure ulcer development in adults and children over the age of five years.",
              "fr": "L'\u00e9chelle de Braden est un outil utilis\u00e9 pour \u00e9valuer le risque de d\u00e9veloppement d'escarres chez les adultes et les enfants de plus de cinq ans."
            },
            "aqlPath": "/content[openEHR-EHR-SECTION.adhoc.v1 and name/value='Braden Scale']/items[openEHR-EHR-OBSERVATION.braden_scale.v1]",
            "children": [
