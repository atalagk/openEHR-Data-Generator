                      "fr": "Capacit\u00e9 de changer et de contr\u00f4ler la position du corps."
                    },
                    "aqlPath": "/content[openEHR-EHR-SECTION.adhoc.v1 and name/value='Braden Scale']/items[openEHR-EHR-OBSERVATION.braden_scale.v1]/data[at0001]/events[at0002]/data[at0003]/items[at0019]/value",
                    "inputs": [
                      {
                        "type": "CODED_TEXT",
                        "list": [
                          {
                            "value": "at0026",
                            "label": "Compl\u00e8tement immobile",
                            "localizedLabels": {
                              "fr": "Compl\u00e8tement immobile",
                              "en": "Completely immobile"
                            },
                            "localizedDescriptions": {
                              "fr": "Ne modifie m\u00eame pas l\u00e9g\u00e8rement la position du corps ou des extr\u00e9mit\u00e9s sans assistance.",
                              "en": "Does not make even slight changes in body or extremity position without assistance."
                            },
                            "ordinal": 1
                          },
                          {
                            "value": "at0027",
                            "label": "Tr\u00e8s limit\u00e9",
                            "localizedLabels": {
                              "fr": "Tr\u00e8s limit\u00e9",
                              "en": "Very limited"
                            },
                            "localizedDescriptions": {
                              "fr": "Effectue de l\u00e9gers changements occasionnels dans la position du corps ou des extr\u00e9mit\u00e9s, mais est incapable de faire des changements fr\u00e9quents ou significatifs ind\u00e9pendamment.",
                              "en": "Makes occasional slight changes in body or extremity position but unable to make frequent or significant changes independently."
                            },
                            "ordinal": 2
                          },
                          {
                            "value": "at0028",
                            "label": "L\u00e9g\u00e8rement limit\u00e9",
                            "localizedLabels": {
                              "fr": "L\u00e9g\u00e8rement limit\u00e9",
                              "en": "Slightly limited"
                            },
                            "localizedDescriptions": {
                              "fr": "Fait des changements fr\u00e9quents mais l\u00e9gers dans la position du corps ou des extr\u00e9mit\u00e9s ind\u00e9pendamment.",
                              "en": "Makes frequent though slight changes in body or extremity position independently."
                            },
                            "ordinal": 3
                          },
